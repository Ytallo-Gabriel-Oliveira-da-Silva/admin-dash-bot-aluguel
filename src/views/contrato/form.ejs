<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="container">
    <h1>Contrato de Licenciamento</h1>
    <% if (error) { %><div class="alert"><%= error %></div><% } %>
    <p>Preencha os dados para formalizar o contrato e seguir para pagamento.</p>
    <form method="post" action="/contrato/<%= contrato.tokenUnico %>/assinar" class="grid">
      <div>
        <label>Nome completo</label>
        <input type="text" name="nomeCompleto" required />
      </div>
      <div>
        <label>CPF/CNPJ</label>
        <input type="text" name="cpfCnpj" required />
      </div>
      <div>
        <label>Email</label>
        <input type="email" name="email" required />
      </div>
      <div>
        <label>Endereço</label>
        <textarea name="endereco" required></textarea>
      </div>
      <div>
        <label class="checkbox-inline"><input type="checkbox" name="aceite" required /> Li e concordo com os termos</label>
      </div>
      <button type="submit">Assinar e continuar</button>
    </form>
  </div>
</body>
</html>
